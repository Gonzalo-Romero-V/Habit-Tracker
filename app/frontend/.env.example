# Build web (default): usada server-side por next.config.ts para el rewrite
# de /api/* — nunca se expone al browser (sin prefijo NEXT_PUBLIC_).
BACKEND_URL=http://localhost:8000

# Build mobile (BUILD_TARGET=mobile, export estático de Capacitor): URL
# absoluta de la API, embebida a propósito en el bundle del cliente.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Selecciona el modo de build: "web" (default) o "mobile". Server-only
# (next.config.ts la usa para decidir output:'export' vs rewrites()).
BUILD_TARGET=web

# Mismo valor que BUILD_TARGET, pero con el prefijo NEXT_PUBLIC_ — sin
# esto el browser no puede leerla (Next.js recorta las env vars sin ese
# prefijo del bundle de cliente). Usada por lib/api.ts para decidir si
# pegarle a la API con URL relativa (rewrite) o absoluta (mobile).
NEXT_PUBLIC_BUILD_TARGET=web

# Client ID de OAuth de Google Cloud (no el secret). Público a propósito
# (Google Identity Services corre client-side) — mismo valor que
# GOOGLE_CLIENT_ID en app/backend/.env.
NEXT_PUBLIC_GOOGLE_CLIENT_ID=

# Client ID (tipo Web) del proyecto de Firebase — usado por GoogleSignInButton.tsx
# SOLO en la rama nativa (Capacitor), nunca en build web. El valor real que
# importa vive en app/frontend/.env.mobile (ver ahí el porqué); se declara
# acá vacío solo para que la variable quede documentada en el build web,
# igual que GOOGLE_CLIENT_ID_ANDROID en app/backend/.env.example.
NEXT_PUBLIC_GOOGLE_CLIENT_ID_ANDROID=
