APP_NAME="Habit Tracker"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=HabitTracker
DB_USERNAME=postgres
DB_PASSWORD=

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

# Origen(es) permitidos por CORS para /api/* (separados por coma, sin slash
# final), ver config/cors.php. La API se autentica con Bearer token, no con
# cookies, así que esto es defensa en profundidad, no el mecanismo real de
# aislamiento (ese es de red: el backend nunca se tunelea, ver DEPLOY.md).
# En local: la URL donde corre `npm run dev` del frontend. En producción:
# la URL pública del frontend (la que expone el túnel de Cloudflare).
# `https://localhost` es obligatorio si existe build mobile: el WebView de
# Capacitor sirve el contenido empaquetado desde ese origen por default
# (server.androidScheme, ver capacitor.config.ts) y sus fetch() a /api/*
# — aunque pasen por el rewrite server-side del frontend — SÍ quedan
# sujetos a CORS normal de browser, porque el Origin real que ve Laravel
# (reenviado tal cual por el rewrite) sigue siendo el del WebView, no el
# del frontend. Sin este origen en la lista, la app instalada falla en
# todas las llamadas a la API con error de CORS (nunca en el browser web).
CORS_ALLOWED_ORIGINS=http://localhost:3000,https://localhost

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Client ID de OAuth de Google Cloud (no el secret — este flujo verifica
# el ID token que ya firmó Google, no necesita client secret). Mismo
# Client ID que NEXT_PUBLIC_GOOGLE_CLIENT_ID en app/frontend/.env.
GOOGLE_CLIENT_ID=

# Client ID (tipo Web) del proyecto de Firebase, usado como serverClientId
# por el Sign-In nativo de Android — audiencia distinta a GOOGLE_CLIENT_ID
# de arriba porque vive en otro proyecto GCP (el que tiene registrado el
# client Android con el SHA-1 del APK; Google exige que ambos coincidan de
# proyecto). Mismo valor que NEXT_PUBLIC_GOOGLE_CLIENT_ID_ANDROID en
# app/frontend/.env.mobile. Ver decisions/stack.md.
GOOGLE_CLIENT_ID_ANDROID=

# Ruta al JSON de cuenta de servicio de Firebase (server-side, para
# despachar push vía FCM — ver domain/reminder.md y decisions/stack.md).
# Se descarga desde la consola de Firebase del proyecto
# (habittracker-7be67) → Configuración del proyecto → Cuentas de
# servicio → Generar nueva clave privada. Nunca se commitea. Si se deja
# vacío, config/firebase.php usa storage_path('app/firebase/service-account.json')
# como default.
FIREBASE_CREDENTIALS=

VITE_APP_NAME="${APP_NAME}"
