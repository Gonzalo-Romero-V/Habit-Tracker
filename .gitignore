# Artefactos del engine vault-sync (no se commitean en proyectos instanciados,
# pero como template también los excluimos por convención)
.vault-sync/

# Python
__pycache__/
*.pyc
*.pyo
*.pyd
.Python
*.egg-info/
.pytest_cache/

# Editors
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db

# Graphify (cuando se usa con --with-graphify, su salida queda fuera de git)
graphify-out/

# Worktrees de subagentes de Claude Code (aislamiento para trabajo paralelo)
.claude/worktrees/

# Credenciales de Firebase — nunca commiteadas (ver decisions/stack.md,
# decisions/environments.md). google-services.json es config de cliente
# Android (vive en android/app/ una vez existe la plataforma Capacitor);
# el *-firebase-adminsdk-*.json es la cuenta de servicio del backend
# (private_key real) y va a app/backend/storage/app/firebase/.
google-services.json
*firebase-adminsdk*.json
app/backend/storage/app/firebase/
