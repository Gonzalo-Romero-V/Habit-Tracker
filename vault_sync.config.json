{
  "schema_version": "1.0",
  "project_name": "Habit Tracker",
  "vault_path": "C:/Users/Gonzalo/Dev/Habit Tracker/vault",
  "extractor": "nextjs-laravel",
  "hierarchy_mapping": {
    "H1_intent": [
      "vault/intent/**"
    ],
    "H2_requirements": [
      "vault/domain/**",
      "vault/raw/**"
    ],
    "H3_architecture": [
      "vault/decisions/**",
      "app/frontend/components.json",
      "app/frontend/tsconfig.json",
      "app/frontend/next.config.*",
      "app/frontend/postcss.config.*",
      "app/frontend/eslint.config.*",
      "app/frontend/src/app/globals.css",
      "app/frontend/package.json",
      "app/backend/composer.json",
      "app/backend/config/**",
      "app/backend/bootstrap/**",
      "app/backend/phpunit.xml",
      ".gitignore",
      ".gitattributes"
    ],
    "H4_contracts": [
      "app/backend/database/migrations/**",
      "app/backend/database/seeders/**",
      "app/backend/database/factories/**",
      "app/backend/routes/**",
      "app/backend/app/Models/**",
      "app/backend/app/Http/Resources/**",
      "app/backend/app/Http/Requests/**",
      "app/backend/app/Policies/**",
      "app/frontend/src/components/ui/**",
      "app/frontend/src/components/layout/**",
      "app/frontend/src/components/custom/**",
      "app/frontend/src/app/api/**",
      "app/frontend/src/lib/**",
      "app/frontend/src/hooks/**",
      "app/frontend/src/types/**",
      "app/frontend/src/app/**/layout.tsx"
    ],
    "H5_implementation": [
      "app/backend/app/Http/Controllers/**",
      "app/backend/app/Http/Middleware/**",
      "app/backend/app/Services/**",
      "app/backend/app/Console/**",
      "app/backend/app/Jobs/**",
      "app/backend/app/Mail/**",
      "app/backend/resources/**",
      "app/frontend/src/app/**/page.tsx",
      "app/frontend/src/app/**/loading.tsx",
      "app/frontend/src/app/**/error.tsx",
      "app/frontend/src/components/**"
    ],
    "ENV_references": [
      "**/.env",
      "**/.env.example",
      "**/.env.local"
    ]
  },
  "exclude_patterns": [
    "**/node_modules/**",
    "**/vendor/**",
    "**/.next/**",
    "**/storage/**",
    "**/bootstrap/cache/**",
    "**/*.lock",
    "**/*-lock.json",
    "**/*.log",
    "**/graphify-out/**",
    "bootstrap/init_vault.py",
    "bootstrap/stacks/**",
    "bootstrap/vault-skeleton/**",
    "scripts/vault_sync.py",
    "scripts/lib/**",
    "hooks/post-commit",
    "CHANGELOG.md"
  ],
  "env_scan_scope": {
    "backend": [
      "app/**",
      "routes/**",
      "database/**"
    ],
    "frontend": [
      "src/app/**",
      "src/components/**",
      "src/lib/**"
    ]
  },
  "vault_protected_status": [
    "locked"
  ],
  "report_size_limits": {
    "max_files": 100,
    "max_diff_chars_per_file": 500,
    "split_threshold_files": 30
  }
}
